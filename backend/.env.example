# YoumeChat Server Configuration
PORT=5000
NODE_ENV=development
API_VERSION=v1

# MongoDB Atlas Database URI
MONGODB_URI=mongodb+srv://Savio:<Dj$avio2006>@savio.gtoc9il.mongodb.net/?appName=Savio
# Redis Configuration (Optional / Scaling fallback)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_ENABLED=false

# JWT Secret Keys
JWT_SECRET=youmechat_super_secret_access_token_key_32bytes_min
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=youmechat_super_secret_refresh_token_key_32bytes_min
JWT_REFRESH_EXPIRES_IN=30d

# Firebase Admin SDK Configuration
FIREBASE_PROJECT_ID=youmechat-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@youmechat-app.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_FIREBASE_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Cloudinary Storage Credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Security & CORS
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
